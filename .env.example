# ─── Telegram ─────────────────────────────────────────────────────────────────
# Получить у @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ─── Anthropic ────────────────────────────────────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── OpenAI (опционально) ─────────────────────────────────────────────────────
# Нужен только для голосовых сообщений (Whisper transcription)
# https://platform.openai.com/api-keys
# Оставь пустым если голосовые не нужны
OPENAI_API_KEY=

# ─── Администратор (Фаза 8.5) ─────────────────────────────────────────────────
# Telegram user_id владельца бота — даёт доступ к /admin панели
# Узнать свой ID: напиши @userinfobot в Telegram
# Оставь 0 или удали строку — /admin будет недоступен всем
ADMIN_USER_ID=0
